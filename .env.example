# Example environment variables (copy to .env and fill values)

# MSSQL
MSSQL_HOST=mssql
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=YourStrong!Passw0rd
MSSQL_DB=ksppolice

# SQLAlchemy style URL (optional if using direct pyodbc)
DATABASE_URL=mssql+pyodbc://sa:YourStrong!Passw0rd@mssql:1433/ksppolice?driver=ODBC+Driver+17+for+SQL+Server

# OpenAI
OPENAI_API_KEY=

# ChromaDB
CHROMA_URL=http://chromadb:8000

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=test

# JWT
JWT_SECRET_KEY=change-this-secret
JWT_ALGORITHM=HS256

# Other
ENV=development
